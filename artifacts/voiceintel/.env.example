# VoiceIntel — Docker environment variables
# Copy to .env and fill in your values. All keys are optional unless noted.

# ── Flask / Security ─────────────────────────────────────────────────────────
# REQUIRED: random string used to sign session cookies
SESSION_SECRET=change-me-to-a-long-random-string

# Flask environment (production | development)
FLASK_ENV=production

# Port the app listens on inside the container
PORT=5000

# Public base URL for emailed links (invitations, etc.). Set this to the
# external hostname users will see — e.g. https://voice-ai.obtv.io
# If left blank the app falls back to the request scheme + Host header,
# which usually works behind a reverse proxy that sets X-Forwarded-Proto.
APP_BASE_URL=

# ── Database ──────────────────────────────────────────────────────────────────
# docker-compose.yml builds DATABASE_URL from this password automatically.
# Only set DATABASE_URL manually if you are pointing at an external Postgres.
DB_PASSWORD=change-me-to-a-strong-password
#DATABASE_URL=postgresql://voiceintel:password@db:5432/voiceintel

# ── Storage ───────────────────────────────────────────────────────────────────
# Directory for raw + converted audio files inside the container.
# Mapped to the "app_storage" Docker volume by default.
STORAGE_DIR=/data/storage

# ── Whisper transcription ─────────────────────────────────────────────────────
# Model size: tiny | base | small | medium | large-v2 | large-v3
# Larger = more accurate but slower and more RAM. "base" is a good default.
WHISPER_MODEL=base

# ── SendGrid — Inbound Parse (voicemail ingestion) ────────────────────────────
# API key with at least "Inbound Parse" permission.
# Can also be configured in the Admin → Integrations UI.
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook authentication token. Append ?token=<this value> to your webhook URL
# in SendGrid → Settings → Inbound Parse. Leave blank to accept all (dev only).
SENDGRID_WEBHOOK_KEY=your-secret-webhook-token

# ── SendGrid — Outbound email (automation notifications) ─────────────────────
# Verified sender address and optional display name.
# Can also be configured in the Admin → Integrations UI.
SENDGRID_FROM_EMAIL=alerts@yourdomain.com
SENDGRID_FROM_NAME=VoiceIntel

# Default recipient for "Notify Admin" trigger actions (comma-separated).
# Can also be configured in the Admin → Integrations UI.
SENDGRID_ADMIN_EMAIL=ops@yourdomain.com

# ── Display timezone ──────────────────────────────────────────────────────────
# IANA zone name used to render timestamps in the UI (dashboard, voicemail
# detail, tasks, analytics, etc). The database always stores UTC; this only
# affects display. Invalid values fall back to UTC with a startup warning.
# Examples: America/Chicago, America/Los_Angeles, America/New_York,
#           Europe/London, Australia/Sydney
DISPLAY_TZ=America/Chicago

