# Database
DATABASE_URL=postgresql://user:password@localhost:5432/voiceintel

# Flask
SECRET_KEY=change-me-in-production
FLASK_ENV=development
PORT=5000

# IMAP Email Settings
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your@email.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX

# Whisper Model
WHISPER_MODEL=base
# Options: tiny, base, small, medium, large-v2

# Storage
STORAGE_DIR=storage

# Polling interval (seconds)
POLL_INTERVAL=60
